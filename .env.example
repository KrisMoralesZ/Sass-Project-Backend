NODE_ENV=development
PORT=3000

API_PREFIX=api
SWAGGER_PATH=api/docs

# Local app + Docker Postgres only: localhost / 5433
# Full Docker stack (docker compose up): overridden to postgres / 5432
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=sass_project
DATABASE_SSL=false
DATABASE_SYNCHRONIZE=true

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Rate limiting
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
AUTH_RATE_LIMIT_TTL_MS=60000
AUTH_RATE_LIMIT_MAX=5

# Account lockout
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
